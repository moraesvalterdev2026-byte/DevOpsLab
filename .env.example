# Arquivo de exemplo para variáveis de ambiente.
# Copie este arquivo para .env e preencha com os valores corretos para o seu ambiente.

# Configurações do Banco de Dados (usado pelo docker-compose e pela aplicação)
DB_USER=axes_user
DB_PASSWORD=axes_pass
DB_NAME=axes_db
DB_HOST=localhost
DB_PORT=5432

# Credenciais para o serviço de IA (usado pelo docker-compose)
IAM_USER=seu_usuario_iam
IAM_TOKEN=seu_token_iam

# Chave secreta para assinar os JSON Web Tokens (JWT)
JWT_SECRET=sua_chave_super_secreta_aqui