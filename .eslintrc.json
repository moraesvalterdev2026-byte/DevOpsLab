{
    "env": {
        "node": true,
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 12
    },
    "globals": {
        "fetchApi": "readonly",
        "loadHeader": "readonly",
        "checkAuth": "readonly",
        "loadComponent": "readonly"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "error"
    }
}
